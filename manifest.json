{
  "manifest_version": 3,
  "name": "Time Reminder",
  "version": "1.0",
  "description": "A Chrome extension to remind users of the current time and help manage their time effectively.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48_1.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },
  "action": {
    "default_popup": "newtab/newtab.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48_1.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles/common.css"]
    }
  ],
  "permissions": ["storage", "activeTab"],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "author": "KUNTAL OJHA",
  "homepage_url": "https://yourhomepage.com"
}
